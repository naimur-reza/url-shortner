generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Url {
  id String @id @default(uuid())
  originalUrl String
  shortCode String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Click Click[]
}

model Click {
  id String @id @default(uuid())
  urlId String 
  ipAddress String?
  userAgent String?
  referrer String?
  createdAt DateTime @default(now())

  Url Url @relation(fields: [urlId], references: [id])
  @@index([urlId])
}